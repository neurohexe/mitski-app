<!-- ============================================ -->
<!-- ===== ПОДКЛЮЧЕНИЕ К GOOGLE SHEETS API ===== -->
<!-- ============================================ -->

<script>
// ============================================
// КОНФИГУРАЦИЯ
// ============================================

// ⚠️ ВСТАВЬТЕ СВОЙ CLIENT ID СЮДА:
const CLIENT_ID = '309525177557-l6vvajhjpt48r7b59qeo2pr0eotdou5h.apps.googleusercontent.com';

// ⚠️ ВСТАВЬТЕ ID ВАШЕЙ ТАБЛИЦЫ:
// Откройте таблицу → скопируйте ID из URL
const SPREADSHEET_ID = '1XIe7P0sZk_HTu2OJtp3pPymBI--S7OKKltbPJn1ldk';

// Настройки API
const API_KEY = ''; // пока оставляем пустым (для OAuth не нужен)
const DISCOVERY_DOC = 'https://sheets.googleapis.com/$discovery/rest?version=v4';
const SCOPES = 'https://www.googleapis.com/auth/spreadsheets';

let tokenClient;
let gapiInited = false;
let gisInited = false;
let isAuthenticated = false;

// ============================================
// ЗАГРУЗКА БИБЛИОТЕК GOOGLE
// ============================================

function gapiLoaded() {
    gapi.load('client', initializeGapiClient);
}

async function initializeGapiClient() {
    await gapi.client.init({
        apiKey: API_KEY,
        discoveryDocs: [DISCOVERY_DOC],
    });
    gapiInited = true;
    maybeEnableButtons();
}

function gisLoaded() {
    tokenClient = google.accounts.oauth2.initTokenClient({
        client_id: CLIENT_ID,
        scope: SCOPES,
        callback: '', // будет определено позже
    });
    gisInited = true;
    maybeEnableButtons();
}

function maybeEnableButtons() {
    if (gapiInited && gisInited) {
        // Кнопки готовы к работе
        console.log('✅ Google API готов к работе');
    }
}

// ============================================
// АВТОРИЗАЦИЯ
// ============================================

function handleAuth() {
    const authBtn = document.getElementById('authBtn');
    
    if (isAuthenticated) {
        // Выход
        handleSignoutClick();
        return;
    }
    
    // Вход
    tokenClient.callback = async (resp) => {
        if (resp.error !== undefined) {
            showToast('Ошибка авторизации: ' + resp.error, 'error');
            throw resp;
        }
        isAuthenticated = true;
        document.getElementById('userStatus').innerHTML = '<i class="fas fa-circle"></i> Авторизован';
        document.getElementById('userStatus').className = 'user-status authenticated';
        authBtn.innerHTML = '<i class="fas fa-sign-out-alt"></i> Выйти';
        authBtn.className = 'btn-auth logout';
        
        showToast('✅ Авторизация выполнена успешно!', 'success');
        await loadAllData();
    };

    if (gapi.client.getToken() === null) {
        tokenClient.requestAccessToken({ prompt: 'consent' });
    } else {
        tokenClient.requestAccessToken({ prompt: '' });
    }
}

function handleSignoutClick() {
    const token = gapi.client.getToken();
    if (token !== null) {
        google.accounts.oauth2.revoke(token.access_token);
        gapi.client.setToken('');
        isAuthenticated = false;
        document.getElementById('userStatus').innerHTML = '<i class="fas fa-circle"></i> Не авторизован';
        document.getElementById('userStatus').className = 'user-status unauthenticated';
        document.getElementById('authBtn').innerHTML = '<i class="fas fa-google"></i> Войти';
        document.getElementById('authBtn').className = 'btn-auth';
        showToast('🔓 Вы вышли из системы', 'info');
    }
}

// ============================================
// РАБОТА С GOOGLE SHEETS
// ============================================

async function readSheet(range) {
    if (!isAuthenticated) {
        showToast('⚠️ Сначала авторизуйтесь!', 'warning');
        return null;
    }
    
    try {
        const response = await gapi.client.sheets.spreadsheets.values.get({
            spreadsheetId: SPREADSHEET_ID,
            range: range,
        });
        return response.result.values || [];
    } catch (err) {
        console.error('Ошибка чтения:', err);
        showToast('Ошибка чтения данных: ' + err.message, 'error');
        return null;
    }
}

async function writeSheet(range, values) {
    if (!isAuthenticated) {
        showToast('⚠️ Сначала авторизуйтесь!', 'warning');
        return null;
    }
    
    try {
        const response = await gapi.client.sheets.spreadsheets.values.update({
            spreadsheetId: SPREADSHEET_ID,
            range: range,
            valueInputOption: 'USER_ENTERED',
            resource: { values: values },
        });
        showToast('✅ Данные сохранены!', 'success');
        return response;
    } catch (err) {
        console.error('Ошибка записи:', err);
        showToast('Ошибка записи: ' + err.message, 'error');
        return null;
    }
}

async function appendRow(range, rowData) {
    if (!isAuthenticated) {
        showToast('⚠️ Сначала авторизуйтесь!', 'warning');
        return null;
    }
    
    try {
        const response = await gapi.client.sheets.spreadsheets.values.append({
            spreadsheetId: SPREADSHEET_ID,
            range: range,
            valueInputOption: 'USER_ENTERED',
            resource: { values: [rowData] },
        });
        showToast('✅ Строка добавлена!', 'success');
        return response;
    } catch (err) {
        console.error('Ошибка добавления:', err);
        showToast('Ошибка добавления: ' + err.message, 'error');
        return null;
    }
}

// ============================================
// ЗАГРУЗКА ДАННЫХ
// ============================================

async function loadAllData() {
    await loadProducts();
    await loadStats();
}

async function loadProducts() {
    const data = await readSheet('Склад_Продукты!A2:E');
    const tbody = document.getElementById('productsTableBody');
    const dashboardTbody = document.getElementById('dashboardTableBody');
    
    if (!data || data.length === 0) {
        tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><i class="fas fa-box"></i><h3>Нет товаров</h3></div></td></tr>';
        dashboardTbody.innerHTML = '<tr><td colspan="5"><div class="empty-state"><i class="fas fa-box"></i><h3>Нет товаров</h3></div></td></tr>';
        return;
    }
    
    let productsHtml = '';
    let dashboardHtml = '';
    
    data.forEach(row => {
        const name = row[0] || '—';
        const qty = row[1] || '0';
        const unit = row[2] || 'шт';
        const category = row[3] || 'Без категории';
        const active = row[4] === 'true' || row[4] === true;
        
        // Определяем статус
        let status = '';
        let statusClass = '';
        if (!active) {
            status = 'Неактивный';
            statusClass = 'inactive';
        } else if (parseInt(qty) < 5) {
            status = 'Низкий остаток';
            statusClass = 'low';
        } else if (parseInt(qty) < 20) {
            status = 'Средний';
            statusClass = 'medium';
        } else {
            status = 'В наличии';
            statusClass = 'high';
        }
        
        // Таблица товаров
        productsHtml += `
            <tr>
                <td>${name}</td>
                <td>${category}</td>
                <td>${qty}</td>
                <td>${unit}</td>
                <td><span class="status-badge ${statusClass}">${status}</span></td>
                <td style="text-align:center;">
                    <button class="action-btn edit" onclick="editProduct('${name}')"><i class="fas fa-edit"></i></button>
                    <button class="action-btn delete" onclick="deleteProduct('${name}')"><i class="fas fa-trash"></i></button>
                </td>
            </tr>
        `;
        
        // Dashboard таблица (без действий)
        dashboardHtml += `
            <tr>
                <td>${name}</td>
                <td>${category}</td>
                <td>${qty}</td>
                <td>${unit}</td>
                <td><span class="status-badge ${statusClass}">${status}</span></td>
            </tr>
        `;
    });
    
    tbody.innerHTML = productsHtml;
    dashboardTbody.innerHTML = dashboardHtml;
}

async function loadStats() {
    const data = await readSheet('Склад_Продукты!A2:E');
    if (!data) return;
    
    let total = 0;
    let active = 0;
    let low = 0;
    
    data.forEach(row => {
        const qty = parseInt(row[1]) || 0;
        const isActive = row[4] === 'true' || row[4] === true;
        total += qty;
        if (isActive) active++;
        if (isActive && qty < 5) low++;
    });
    
    document.getElementById('statTotal').textContent = data.length;
    document.getElementById('statActive').textContent = active;
    document.getElementById('statLow').textContent = low;
    document.getElementById('statOrders').textContent = '—';
}

// ============================================
// ФУНКЦИИ ДЛЯ ИНТЕРФЕЙСА
// ============================================

function refreshData() {
    if (!isAuthenticated) {
        showToast('⚠️ Сначала авторизуйтесь!', 'warning');
        return;
    }
    loadAllData();
    showToast('🔄 Данные обновлены', 'info');
}

function refreshProducts() {
    refreshData();
}

function openAddProductModal() {
    if (!isAuthenticated) {
        showToast('⚠️ Сначала авторизуйтесь!', 'warning');
        return;
    }
    // Здесь будет модальное окно для добавления товара
    showToast('🚧 Функция добавления в разработке', 'info');
}

function editProduct(name) {
    showToast('✏️ Редактирование: ' + name, 'info');
}

function deleteProduct(name) {
    if (confirm(`Удалить товар "${name}"?`)) {
        showToast('🗑️ Товар удален: ' + name, 'warning');
    }
}

function createOrder() {
    showToast('🚧 Функция создания заказа в разработке', 'info');
}

function generateReport(type) {
    const resultDiv = document.getElementById('reportResult');
    const reportTypes = {
        products: '📊 Отчет по товарам: Всего ' + document.getElementById('statTotal').textContent + ' позиций',
        orders: '📊 Отчет по заказам: История заказов',
        stock: '📊 Анализ остатков: ' + document.getElementById('statLow').textContent + ' товаров с низким остатком',
        categories: '📊 По категориям: Продукты, Хозтовары, Канцелярия, Медикаменты'
    };
    resultDiv.innerHTML = `
        <div class="stat-card" style="padding:20px;">
            <h3 style="margin-bottom:8px;">${reportTypes[type] || 'Отчет'}</h3>
            <p style="color:#6b7a8f;">Отчет сгенерирован в ${new Date().toLocaleTimeString()}</p>
        </div>
    `;
}

function saveSheetId() {
    const id = document.getElementById('sheetIdInput').value.trim();
    if (id) {
        localStorage.setItem('spreadsheetId', id);
        showToast('✅ ID таблицы сохранен', 'success');
    } else {
        showToast('⚠️ Введите ID таблицы', 'warning');
    }
}

function loadSheetId() {
    const id = localStorage.getItem('spreadsheetId');
    if (id) {
        document.getElementById('sheetIdInput').value = id;
        showToast('✅ ID таблицы загружен', 'success');
    } else {
        showToast('⚠️ ID таблицы не найден', 'warning');
    }
}

function testConnection() {
    const statusDiv = document.getElementById('connectionStatus');
    if (isAuthenticated) {
        statusDiv.innerHTML = '✅ Подключение к Google Sheets установлено!';
        statusDiv.style.background = '#e8f5e9';
        statusDiv.style.color = '#2e7d32';
        showToast('✅ Подключение успешно!', 'success');
    } else {
        statusDiv.innerHTML = '❌ Нет авторизации. Нажмите "Войти"';
        statusDiv.style.background = '#fce4ec';
        statusDiv.style.color = '#c62828';
        showToast('⚠️ Сначала авторизуйтесь', 'warning');
    }
}

function filterDashboard() {
    // Фильтрация на dashboard
    const search = document.getElementById('dashboardSearch').value.toLowerCase();
    const filter = document.getElementById('dashboardFilter').value;
    const rows = document.querySelectorAll('#dashboardTableBody tr');
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        const category = row.querySelector('td:nth-child(2)')?.textContent || '';
        const show = text.includes(search) && (filter === 'all' || category.includes(filter));
        row.style.display = show ? '' : 'none';
    });
}

function filterProducts() {
    // Фильтрация на странице товаров
    const search = document.getElementById('productsSearch').value.toLowerCase();
    const filter = document.getElementById('productsFilter').value;
    const statusFilter = document.getElementById('productsStatusFilter').value;
    const rows = document.querySelectorAll('#productsTableBody tr');
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        const category = row.querySelector('td:nth-child(2)')?.textContent || '';
        const status = row.querySelector('td:nth-child(5)')?.textContent || '';
        const show = text.includes(search) && 
                    (filter === 'all' || category.includes(filter)) &&
                    (statusFilter === 'all' || 
                     (statusFilter === 'active' && !status.includes('Неактивный')) ||
                     (statusFilter === 'inactive' && status.includes('Неактивный')));
        row.style.display = show ? '' : 'none';
    });
}

// ============================================
// TOAST / УВЕДОМЛЕНИЯ
// ============================================

function showToast(message, type = 'info') {
    const container = document.getElementById('toastContainer');
    if (!container) {
        // Создаем контейнер если его нет
        const newContainer = document.createElement('div');
        newContainer.id = 'toastContainer';
        newContainer.className = 'toast-container';
        document.body.appendChild(newContainer);
    }
    
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.innerHTML = `
        <i class="fas ${type === 'success' ? 'fa-check-circle' : 
                        type === 'error' ? 'fa-exclamation-circle' : 
                        type === 'warning' ? 'fa-exclamation-triangle' : 'fa-info-circle'}"></i>
        <span>${message}</span>
        <button class="toast-close" onclick="this.parentElement.remove()">&times;</button>
    `;
    
    document.getElementById('toastContainer').appendChild(toast);
    
    setTimeout(() => {
        if (toast.parentElement) {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(100px)';
            setTimeout(() => toast.remove(), 300);
        }
    }, 5000);
}

// ============================================
// ПЕРЕКЛЮЧЕНИЕ ВКЛАДОК
// ============================================

document.querySelectorAll('.nav-links button').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.nav-links button').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        document.querySelectorAll('.tab-content').forEach(tab => tab.classList.remove('active'));
        const tabId = 'tab-' + this.dataset.tab;
        document.getElementById(tabId).classList.add('active');
    });
});

// ============================================
// ЗАПУСК ПРИЛОЖЕНИЯ
// ============================================

console.log('🚀 Складской учет загружен');
console.log('📋 Client ID:', CLIENT_ID);
console.log('📊 Spreadsheet ID:', SPREADSHEET_ID);

// Проверяем, есть ли сохраненный ID таблицы
const savedId = localStorage.getItem('spreadsheetId');
if (savedId) {
    document.getElementById('sheetIdInput').value = savedId;
}

// ============================================
// ПОДКЛЮЧЕНИЕ БИБЛИОТЕК GOOGLE
// ============================================
</script>

