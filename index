<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Складской учет - Управление товарами</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <style>
        /* ===== RESET & BASE ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #f0f2f5;
            color: #1a1a2e;
            min-height: 100vh;
        }
        
        /* ===== SCROLLBAR ===== */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #e8eaed; border-radius: 8px; }
        ::-webkit-scrollbar-thumb { background: #c1c7cd; border-radius: 8px; }
        ::-webkit-scrollbar-thumb:hover { background: #a8afb6; }
        
        /* ===== HEADER / NAVBAR ===== */
        .navbar {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .navbar .logo {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #fff;
            font-size: 22px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }
        
        .navbar .logo i {
            font-size: 28px;
            color: #4fc3f7;
        }
        
        .navbar .logo span {
            background: linear-gradient(90deg, #4fc3f7, #81c784);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .nav-links {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
        }
        
        .nav-links button {
            background: rgba(255,255,255,0.08);
            border: none;
            color: #b0bec5;
            padding: 8px 18px;
            border-radius: 8px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: inherit;
        }
        
        .nav-links button:hover {
            background: rgba(255,255,255,0.16);
            color: #fff;
        }
        
        .nav-links button.active {
            background: #4fc3f7;
            color: #1a1a2e;
        }
        
        .nav-links button i {
            font-size: 16px;
        }
        
        /* ===== AUTH BUTTON ===== */
        .auth-section {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        
        .auth-section .user-status {
            color: #b0bec5;
            font-size: 13px;
        }
        
        .auth-section .user-status i {
            color: #81c784;
            margin-right: 4px;
        }
        
        .btn-auth {
            background: #4fc3f7;
            border: none;
            color: #1a1a2e;
            padding: 8px 20px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: inherit;
        }
        
        .btn-auth:hover {
            background: #81d4fa;
            transform: scale(1.03);
        }
        
        .btn-auth.logout {
            background: #ef5350;
            color: #fff;
        }
        
        .btn-auth.logout:hover {
            background: #e53935;
        }
        
        /* ===== MAIN CONTAINER ===== */
        .main-container {
            max-width: 1440px;
            margin: 0 auto;
            padding: 24px 32px 40px;
        }
        
        /* ===== TAB CONTENT ===== */
        .tab-content {
            display: none;
            animation: fadeIn 0.4s ease;
        }
        
        .tab-content.active {
            display: block;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* ===== PAGE HEADER ===== */
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 24px;
        }
        
        .page-header h1 {
            font-size: 28px;
            font-weight: 700;
            color: #1a1a2e;
        }
        
        .page-header h1 i {
            color: #4fc3f7;
            margin-right: 10px;
        }
        
        .page-header .subtitle {
            color: #6b7a8f;
            font-size: 14px;
            font-weight: 400;
        }
        
        .page-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #4fc3f7, #29b6f6);
            border: none;
            color: #1a1a2e;
            padding: 10px 24px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: inherit;
            box-shadow: 0 4px 12px rgba(79, 195, 247, 0.3);
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(79, 195, 247, 0.4);
        }
        
        .btn-secondary {
            background: #e8eaed;
            border: none;
            color: #3c4043;
            padding: 10px 24px;
            border-radius: 10px;
            font-weight: 500;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: inherit;
        }
        
        .btn-secondary:hover {
            background: #d2d5d9;
        }
        
        .btn-success {
            background: linear-gradient(135deg, #81c784, #66bb6a);
            border: none;
            color: #fff;
            padding: 10px 24px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: inherit;
        }
        
        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 187, 106, 0.4);
        }
        
        .btn-danger {
            background: #ef5350;
            border: none;
            color: #fff;
            padding: 10px 24px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: inherit;
        }
        
        .btn-danger:hover {
            background: #e53935;
        }
        
        /* ===== STATS CARDS ===== */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 28px;
        }
        
        .stat-card {
            background: #fff;
            border-radius: 14px;
            padding: 18px 22px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            border: 1px solid #e8eaed;
            transition: all 0.3s ease;
        }
        
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        }
        
        .stat-card .stat-label {
            font-size: 13px;
            color: #6b7a8f;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .stat-card .stat-value {
            font-size: 28px;
            font-weight: 700;
            color: #1a1a2e;
            margin-top: 4px;
        }
        
        .stat-card .stat-icon {
            float: right;
            font-size: 28px;
            opacity: 0.3;
        }
        
        /* ===== TABLE ===== */
        .table-container {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            border: 1px solid #e8eaed;
            overflow: hidden;
        }
        
        .table-toolbar {
            padding: 16px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
            border-bottom: 1px solid #e8eaed;
            background: #fafbfc;
        }
        
        .table-toolbar .search-box {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #fff;
            border: 1px solid #d2d5d9;
            border-radius: 8px;
            padding: 6px 14px;
            flex: 1;
            min-width: 200px;
            max-width: 400px;
        }
        
        .table-toolbar .search-box i {
            color: #6b7a8f;
            font-size: 14px;
        }
        
        .table-toolbar .search-box input {
            border: none;
            outline: none;
            padding: 6px 0;
            font-size: 14px;
            width: 100%;
            font-family: inherit;
            background: transparent;
        }
        
        .table-toolbar .filter-select {
            padding: 8px 14px;
            border: 1px solid #d2d5d9;
            border-radius: 8px;
            font-size: 13px;
            font-family: inherit;
            background: #fff;
            color: #1a1a2e;
            cursor: pointer;
        }
        
        .table-wrapper {
            overflow-x: auto;
            padding: 0 4px 4px 4px;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
        }
        
        table thead {
            background: #f8f9fa;
        }
        
        table thead th {
            padding: 14px 16px;
            text-align: left;
            font-weight: 600;
            color: #3c4043;
            border-bottom: 2px solid #e8eaed;
            white-space: nowrap;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }
        
        table tbody td {
            padding: 12px 16px;
            border-bottom: 1px solid #f0f2f5;
            color: #1a1a2e;
            vertical-align: middle;
        }
        
        table tbody tr:hover {
            background: #f8f9fa;
        }
        
        table tbody tr:last-child td {
            border-bottom: none;
        }
        
        .status-badge {
            display: inline-block;
            padding: 3px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        
        .status-badge.active {
            background: #e8f5e9;
            color: #2e7d32;
        }
        
        .status-badge.inactive {
            background: #fce4ec;
            color: #c62828;
        }
        
        .status-badge.low {
            background: #fff3e0;
            color: #e65100;
        }
        
        .status-badge.medium {
            background: #e3f2fd;
            color: #0d47a1;
        }
        
        .status-badge.high {
            background: #e8f5e9;
            color: #1b5e20;
        }
        
        .action-btn {
            background: none;
            border: none;
            padding: 4px 8px;
            cursor: pointer;
            color: #6b7a8f;
            border-radius: 4px;
            transition: all 0.2s ease;
            font-size: 14px;
        }
        
        .action-btn:hover {
            background: #e8eaed;
            color: #1a1a2e;
        }
        
        .action-btn.edit:hover {
            color: #1976d2;
        }
        
        .action-btn.delete:hover {
            color: #d32f2f;
        }
        
        /* ===== MODAL ===== */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            backdrop-filter: blur(6px);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .modal-overlay.active {
            display: flex;
        }
        
        .modal {
            background: #fff;
            border-radius: 18px;
            max-width: 580px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 24px 80px rgba(0,0,0,0.3);
            animation: modalSlideIn 0.3s ease;
        }
        
        @keyframes modalSlideIn {
            from { opacity: 0; transform: scale(0.95) translateY(20px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }
        
        .modal-header {
            padding: 20px 24px 16px;
            border-bottom: 1px solid #e8eaed;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        
        .modal-header h2 {
            font-size: 20px;
            font-weight: 700;
            color: #1a1a2e;
        }
        
        .modal-header h2 i {
            color: #4fc3f7;
            margin-right: 8px;
        }
        
        .modal-close {
            background: none;
            border: none;
            font-size: 24px;
            cursor: pointer;
            color: #6b7a8f;
            transition: all 0.2s ease;
            padding: 0 4px;
        }
        
        .modal-close:hover {
            color: #1a1a2e;
            transform: rotate(90deg);
        }
        
        .modal-body {
            padding: 24px;
        }
        
        .modal-body .form-group {
            margin-bottom: 18px;
        }
        
        .modal-body .form-group label {
            display: block;
            font-weight: 600;
            font-size: 13px;
            color: #3c4043;
            margin-bottom: 5px;
        }
        
        .modal-body .form-group label .required {
            color: #ef5350;
        }
        
        .modal-body .form-group input,
        .modal-body .form-group select,
        .modal-body .form-group textarea {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #d2d5d9;
            border-radius: 8px;
            font-size: 14px;
            font-family: inherit;
            transition: all 0.2s ease;
            background: #fafbfc;
        }
        
        .modal-body .form-group input:focus,
        .modal-body .form-group select:focus,
        .modal-body .form-group textarea:focus {
            outline: none;
            border-color: #4fc3f7;
            box-shadow: 0 0 0 3px rgba(79, 195, 247, 0.15);
            background: #fff;
        }
        
        .modal-body .form-group textarea {
            resize: vertical;
            min-height: 60px;
        }
        
        .modal-body .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }
        
        .modal-footer {
            padding: 16px 24px 24px;
            border-top: 1px solid #e8eaed;
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }
        
        /* ===== LOADING ===== */
        .loading-spinner {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px 20px;
            color: #6b7a8f;
            font-size: 16px;
            gap: 12px;
        }
        
        .loading-spinner i {
            font-size: 32px;
            color: #4fc3f7;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #6b7a8f;
        }
        
        .empty-state i {
            font-size: 48px;
            opacity: 0.3;
            margin-bottom: 12px;
        }
        
        .empty-state h3 {
            font-size: 18px;
            color: #3c4043;
            margin-bottom: 6px;
        }
        
        /* ===== TOAST ===== */
        .toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        
        .toast {
            padding: 14px 22px;
            border-radius: 12px;
            color: #fff;
            font-weight: 500;
            font-size: 14px;
            box-shadow: 0 6px 24px rgba(0,0,0,0.2);
            animation: slideUp 0.3s ease;
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 280px;
        }
        
        .toast.success { background: #43a047; }
        .toast.error { background: #e53935; }
        .toast.info { background: #1e88e5; }
        .toast.warning { background: #fb8c00; }
        
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .navbar {
                padding: 12px 16px;
            }
            .navbar .logo {
                font-size: 18px;
            }
            .nav-links button {
                font-size: 12px;
                padding: 6px 12px;
            }
            .main-container {
                padding: 16px;
            }
            .page-header h1 {
                font-size: 22px;
            }
            .modal-body .form-row {
                grid-template-columns: 1fr;
            }
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .table-toolbar {
                flex-direction: column;
                align-items: stretch;
            }
            .table-toolbar .search-box {
                max-width: 100%;
            }
            .modal {
                max-width: 100%;
                margin: 10px;
            }
            .auth-section .user-status {
                font-size: 12px;
            }
        }
        
        @media (max-width: 480px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
            .navbar .logo span {
                font-size: 16px;
            }
        }
    </style>
</head>
<body>

<!-- ===== NAVBAR ===== -->
<nav class="navbar">
    <div class="logo">
        <i class="fas fa-warehouse"></i>
        <span>Складской учет</span>
    </div>
    
    <div class="nav-links" id="navLinks">
        <button class="active" data-tab="dashboard">
            <i class="fas fa-chart-pie"></i> Панель
        </button>
        <button data-tab="products">
            <i class="fas fa-boxes"></i> Товары
        </button>
        <button data-tab="orders">
            <i class="fas fa-clipboard-list"></i> Заказы
        </button>
        <button data-tab="reports">
            <i class="fas fa-file-alt"></i> Отчеты
        </button>
        <button data-tab="settings">
            <i class="fas fa-cog"></i> Настройки
        </button>
    </div>
    
    <div class="auth-section">
        <span class="user-status" id="userStatus">
            <i class="fas fa-circle"></i> Не авторизован
        </span>
        <button class="btn-auth" id="authBtn" onclick="handleAuth()">
            <i class="fas fa-google"></i> Войти
        </button>
    </div>
</nav>

<!-- ===== MAIN ===== -->
<div class="main-container">

    <!-- ===== DASHBOARD TAB ===== -->
    <div class="tab-content active" id="tab-dashboard">
        <div class="page-header">
            <div>
                <h1><i class="fas fa-chart-pie"></i> Панель управления</h1>
                <span class="subtitle">Общая статистика склада</span>
            </div>
            <div class="page-actions">
                <button class="btn-primary" onclick="refreshData()">
                    <i class="fas fa-sync-alt"></i> Обновить
                </button>
            </div>
        </div>
        
        <div class="stats-grid" id="statsGrid">
            <div class="stat-card">
                <span class="stat-icon"><i class="fas fa-boxes"></i></span>
                <div class="stat-label">Всего товаров</div>
                <div class="stat-value" id="statTotal">—</div>
            </div>
            <div class="stat-card">
                <span class="stat-icon"><i class="fas fa-check-circle"></i></span>
                <div class="stat-label">Активных</div>
                <div class="stat-value" id="statActive">—</div>
            </div>
            <div class="stat-card">
                <span class="stat-icon"><i class="fas fa-exclamation-triangle"></i></span>
                <div class="stat-label">Низкий остаток</div>
                <div class="stat-value" id="statLow">—</div>
            </div>
            <div class="stat-card">
                <span class="stat-icon"><i class="fas fa-shopping-cart"></i></span>
                <div class="stat-label">Заказов сегодня</div>
                <div class="stat-value" id="statOrders">—</div>
            </div>
        </div>
        
        <div class="table-container">
            <div class="table-toolbar">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Поиск товаров..." id="dashboardSearch" oninput="filterDashboard()" />
                </div>
                <select class="filter-select" id="dashboardFilter" onchange="filterDashboard()">
                    <option value="all">Все категории</option>
                    <option value="Продукты">Продукты</option>
                    <option value="Хозтовары">Хозтовары</option>
                    <option value="Канцелярия">Канцелярия</option>
                    <option value="Медикаменты">Медикаменты</option>
                </select>
            </div>
            <div class="table-wrapper">
                <table>
                    <thead>
                        <tr>
                            <th>Название</th>
                            <th>Категория</th>
                            <th>Количество</th>
                            <th>Ед. изм.</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody id="dashboardTableBody">
                        <tr><td colspan="5"><div class="loading-spinner"><i class="fas fa-spinner"></i> Загрузка...</div></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ===== PRODUCTS TAB ===== -->
    <div class="tab-content" id="tab-products">
        <div class="page-header">
            <div>
                <h1><i class="fas fa-boxes"></i> Управление товарами</h1>
                <span class="subtitle">Добавление, редактирование и удаление товаров</span>
            </div>
            <div class="page-actions">
                <button class="btn-success" onclick="openAddProductModal()">
                    <i class="fas fa-plus"></i> Добавить товар
                </button>
                <button class="btn-secondary" onclick="refreshProducts()">
                    <i class="fas fa-sync-alt"></i> Обновить
                </button>
            </div>
        </div>
        
        <div class="table-container">
            <div class="table-toolbar">
                <div class="search-box">
                    <i class="fas fa-search"></i>
